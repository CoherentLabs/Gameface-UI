---
// CodePreviewGFUI.astro — thin wrapper. Mostly exists to give you a code panel
// next to the preview and to keep MDX usage clean.
import { Code } from 'astro:components';
import PreviewIsland from './PreviewIsland.tsx';


interface Props {
    css?: string | string[];
    height?: number;
    // Raw source string for the displayed code panel (see note below).
    code?: string;
    hash?: string;
}
const { css, height, code, hash } = Astro.props;
---

<div class="gfui-preview">
    <div class="gfui-preview__stage">
        {/* The island hydrates client-side; children pass through as the demo JSX */}
        <PreviewIsland css={css} height={height} code={code} hash={hash} client:load />
    </div>
    {code && <Code code={code} lang="tsx" class="gfui-preview__code" />}
</div>

<style>
    .gfui-preview {
        border: 1px solid var(--sl-color-gray-5, #d0d0d0);
        border-radius: 8px;
        overflow: hidden;
        margin: 1.5rem 0;
        display: flex;
    }
    .gfui-preview__stage {
        background: var(--sl-color-bg, #fff);
        flex-basis: 50%;
    }

    .gfui-preview__stage iframe {
        margin-top: 0;
        background-color: transparent;
    }
    .gfui-preview__code {
        margin: 0;
        border-top: 1px solid var(--sl-color-gray-5, #d0d0d0);
        padding: 1rem;
        overflow-x: auto;
        font-size: 0.85rem;
        flex-basis: 50%;
        overflow-y: auto;
    }
</style>
