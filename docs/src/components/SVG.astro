---
export interface Props {
  path: string;
  width?: string;
  height?: string;
  translate?: string;
  inline?: boolean;
}

const { path, width, height, translate } = Astro.props as Props;

const rawSvgs = import.meta.glob("/src/assets/**/*.svg", {
  query: "?raw",
  import: "default",
});

const matchedKey = Object.keys(rawSvgs).find((key) => key.includes(`${path}`));

if (!matchedKey) {
  throw new Error(`SVG not found for path: ${path}`);
}

const svgContent = (await rawSvgs[matchedKey]()) as string;

const wrapperStyles = {
  display: "inline-flex",
  width: width || "auto",
  height: height || "18vh",
  maxWidth: "33vh",
  transform: translate ? `translate(${translate})` : undefined,
};
---

<span class="svg-inline-wrapper" style={wrapperStyles} set:html={svgContent} />

<style>
  .svg-inline-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
